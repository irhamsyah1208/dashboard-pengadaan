{
  "build": {
    "builder": "NIXPACKS",
    "nixpacksConfig": {
      "phases": {
        "setup": {
          "aptPkgs": ["python3", "python3-pip", "sqlite3"]
        },
        "install": {
          "cmds": [
            "pip3 install -r requirements.txt",
            "npm install"
          ]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "npm start",
    "healthcheckPath": "/api/health",
    "restartPolicyType": "ON_FAILURE",
    "numReplicas": 1
  }
}